# Gunakan image Python yang ringan
FROM python:3.12-slim

# Set working directory di dalam container
WORKDIR /app

# Salin file requirement dan install dependensi
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Salin seluruh kode proyek ke container
COPY . .

# Expose port yang digunakan FastAPI/Uvicorn (misal: 8000)
EXPOSE 8000

# Perintah untuk menjalankan server menggunakan Uvicorn
# --proxy-headers & --forwarded-allow-ips penting jika berada di belakang Reverse Proxy (CasaOS/Cloudflare)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers", "--forwarded-allow-ips", "*"]